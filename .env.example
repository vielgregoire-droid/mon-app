# ============================================
# VARIABLES D'ENVIRONNEMENT — mon-app
# ============================================
# Copie ce fichier en .env.local et remplis les valeurs
# cp .env.example .env.local

# --- Supabase (obligatoire) ---
# Trouve ces valeurs dans : Supabase Dashboard > Settings > API Keys
NEXT_PUBLIC_SUPABASE_URL=https://VOTRE_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...votre-anon-key
SUPABASE_SERVICE_ROLE_KEY=eyJ...votre-service-role-key

# --- Variables pour Vercel (à configurer dans le dashboard Vercel) ---
# Les mêmes variables ci-dessus doivent être ajoutées dans :
# Vercel > Project Settings > Environment Variables

# --- Variables pour GitHub Actions (à configurer dans GitHub Secrets) ---
# VERCEL_TOKEN=votre-token-vercel
# VERCEL_ORG_ID=votre-org-id
# VERCEL_PROJECT_ID=votre-project-id
